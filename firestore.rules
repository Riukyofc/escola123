rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: Safe Auth Check ──
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Helper: Safe Role Extraction (Supports string, list, roles, role) ──
    function getUserRoles() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', [])
          )
        : [];
    }

    function isRole(role) {
      return request.auth != null && (
        (getUserRoles() is list && role in getUserRoles()) ||
        (getUserRoles() is string && role == getUserRoles())
      );
    }

    function isAnyRole(roles) {
      return request.auth != null && (
        (getUserRoles() is list && getUserRoles().hasAny(roles)) ||
        (getUserRoles() is string && getUserRoles() in roles)
      );
    }

    // ── Helper: Safe School Extraction (Supports string, list, escolaIds, escolaId) ──
    function getUserEscolaIds() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('escolaIds', 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('escolaId', [])
          )
        : [];
    }

    function hasAccessToSchool(escolaId) {
      return request.auth != null && (
        (getUserEscolaIds() is list && (escolaId in getUserEscolaIds() || getUserEscolaIds() == [])) ||
        (getUserEscolaIds() is string && (escolaId == getUserEscolaIds() || getUserEscolaIds() == ''))
      );
    }

    // ── Escolas da Rede: read for authenticated, write for secretaria/diretor ──
    match /escolas_rede/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Legacy: Escola info (mantido para compatibilidade) ──
    match /escola/{doc} {
      allow read: if true;
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Legacy: Config (mantido para compatibilidade) ──
    match /config/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Users: each user reads their own, diretor can read/write all ──
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if request.auth.uid == uid || isAnyRole(['diretor', 'secretaria']);
    }

    // ── Alunos: read for all (CPF check during registration), write for diretor ──
    match /alunos/{id} {
      allow read: if true;
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Professores: read for authenticated, write for diretor ──
    match /professores/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Turmas: read for authenticated, write for diretor ──
    match /turmas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Disciplinas: read for authenticated, write for diretor ──
    match /disciplinas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Notas: read for authenticated, write for professor + diretor ──
    match /notas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['professor', 'diretor', 'secretaria']);
    }

    // ── Frequencia: read for authenticated, write for professor + diretor ──
    match /frequencia/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['professor', 'diretor', 'secretaria']);
    }

    // ── Diario: read for authenticated, write for professor + diretor ──
    match /diario/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['professor', 'diretor', 'secretaria']);
    }

    // ── Atividades: read for authenticated, write for professor + diretor ──
    match /atividades/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['professor', 'diretor', 'secretaria']);
    }

    // ── AEE: read for authenticated, write for professor + diretor ──
    match /aee/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['professor', 'diretor', 'secretaria']);
    }

    // ── Avisos: read for all (public), write for professor + diretor ──
    match /avisos/{id} {
      allow read: if true;
      allow write: if isAnyRole(['professor', 'diretor', 'secretaria']);
    }

    // ── SEMED: Repasses Financeiros — secretaria + diretor only ──
    match /repasses_financeiros/{id} {
      allow read: if isAnyRole(['diretor', 'secretaria']);
      allow write: if isAnyRole(['secretaria']);
    }

    // ── SEMED: Estoque de Merenda — secretaria + diretor only ──
    match /estoque_merenda/{id} {
      allow read: if isAnyRole(['diretor', 'secretaria']);
      allow write: if isAnyRole(['secretaria']);
    }

    // ── SEMED: Circulares — read for diretor + secretaria, write for secretaria ──
    match /circulares/{id} {
      allow read: if isAnyRole(['diretor', 'secretaria']);
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── SEMED: Histórico IDEB — read for all authenticated, write for secretaria ──
    match /ideb_historico/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['secretaria']);
    }

    // ── SEMED: Consumo de Merenda ──
    match /consumo_merenda/{id} {
      allow read: if isAnyRole(['diretor', 'secretaria']);
      allow write: if isAnyRole(['secretaria']);
    }

    // ── Direção: Horários, Galeria, Equipe, Depoimentos (public read) ──
    match /horarios_aula/{id} {
      allow read: if true;
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }
    match /galeria/{id} {
      allow read: if true;
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }
    match /equipe/{id} {
      allow read: if true;
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }
    match /depoimentos/{id} {
      allow read: if true;
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }
    match /eventos_calendario/{id} {
      allow read: if true;
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Phase 2: Academic structure (reference data) ──
    match /modalidades_ensino/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }
    match /niveis_ensino/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria']);
    }

    // ── Phase 3: Carga Horária ──
    match /registro_carga_horaria/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['diretor', 'secretaria', 'professor']);
    }

    // ── Phase 4: Dicionário INEP ──
    match /dicionario_inep/{id} {
      allow read: if isAuthenticated();
      allow write: if isAnyRole(['secretaria']);
    }

    // ── Audit Logs: read for diretor/secretaria, write for all authenticated ──
    match /audit_logs/{id} {
      allow read: if isAnyRole(['diretor', 'secretaria']);
      allow create: if isAuthenticated();
    }

    // ── Mensagens: read/write for all authenticated ──
    match /mensagens/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}
